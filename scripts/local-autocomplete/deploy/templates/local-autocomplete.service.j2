[Unit]
Description=local-autocomplete (Ollama code-completion backend)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/ollama serve
User=ollama
Group=ollama
Restart=always
RestartSec=3
{% for k, v in ollama_env.items() %}
Environment="{{ k }}={{ v }}"
{% endfor %}

[Install]
WantedBy=multi-user.target
